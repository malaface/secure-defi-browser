# =============================================
# Secure DeFi Browser - Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.

# === VPN Provider ===
# Gluetun supports 60+ providers. See full list:
# https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=protonvpn

# === WireGuard Credentials ===
# ProtonVPN: Settings > WireGuard > Create credentials
# Mullvad:   Account > WireGuard configuration
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
WIREGUARD_ADDRESSES=10.2.0.2/32

# === VPN Server Location ===
# Privacy-friendly options: Switzerland, Iceland, Sweden, Romania
VPN_SERVER_COUNTRIES=Switzerland

# === Browser Access ===
# Credentials for the KasmVNC web interface at https://localhost:6901
BROWSER_PASSWORD=change_me_to_a_strong_password
BROWSER_USER=user

# === Cloudflare Tunnel ===
# 1. Go to https://one.dash.cloudflare.com/ > Networks > Tunnels
# 2. Create a tunnel and copy the token
# 3. Configure a Public Hostname pointing to http://gluetun:6901
#    - In TLS settings, enable "No TLS Verify" (KasmVNC uses self-signed cert)
# 4. MANDATORY: Configure an Access policy for your hostname (Zero Trust > Access)
#
# Leave empty to run without remote access (localhost only)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# === Timezone ===
TZ=UTC

# === Docker Network ===
# Docker subnets allowed through Gluetun's firewall.
# Default covers standard Docker ranges. Adjust if your setup differs.
FIREWALL_OUTBOUND_SUBNETS=172.16.0.0/12
